# URL absoluta del backend Laravel.
# - Web/desarrollo: DÉJALO VACÍO (se usa el proxy de Vite a localhost:8000).
# - App móvil (Capacitor) o frontend desplegado en otro dominio: pon la URL pública del backend.
#   Ej: VITE_API_URL=https://api.logix.com
VITE_API_URL=

# URL pública del sistema para los enlaces/QR de reservas (si difiere del origen actual).
# Ej: VITE_PUBLIC_URL=https://app.logix.com
VITE_PUBLIC_URL=
