APP_NAME=Logix
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://TU-BACKEND-RENDER.onrender.com
FRONTEND_URL=https://TU-FRONTEND-VERCEL.vercel.app

LOG_CHANNEL=stack
LOG_LEVEL=warning

# Produccion persistente recomendada: Render Postgres o Postgres administrado externo.
DB_CONNECTION=pgsql
DB_HOST=TU_HOST_POSTGRES
DB_PORT=5432
DB_DATABASE=TU_DATABASE
DB_USERNAME=TU_USER
DB_PASSWORD=TU_PASSWORD
DB_SSLMODE=require

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=public

# SMTP real para facturas.
MAIL_MAILER=smtp
MAIL_HOST=TU_SMTP_HOST
MAIL_PORT=587
MAIL_USERNAME=TU_SMTP_USER
MAIL_PASSWORD=TU_SMTP_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=facturacion@tudominio.com
MAIL_FROM_NAME="${APP_NAME}"
