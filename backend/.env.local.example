APP_NAME=Logix
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Opcion recomendada local con Laragon/MySQL.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=logix_local
DB_USERNAME=root
DB_PASSWORD=

# Alternativa local aislada con SQLite:
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=public

# En local no envia correos reales; los escribe en storage/logs.
MAIL_MAILER=log
MAIL_FROM_ADDRESS=no-reply@localhost.test
MAIL_FROM_NAME="${APP_NAME}"
